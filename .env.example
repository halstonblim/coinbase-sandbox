# Copy this file to .env and fill in your actual secrets.
# .env is gitignored and should never be committed.

# Advanced Trade REST credentials used by list_products.py/list_products.sh
COINBASE_REST_KEY_ID="your-rest-key-id"
COINBASE_REST_KEY_SECRET="your-rest-key-secret"

# Notebook / WebSocket credentials
COINBASE_API_KEY="organizations/your-org-id/apiKeys/your-api-key-id"
SIGNING_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END EC PRIVATE KEY-----\n"

# Optional local development keys
OPENAI_API_KEY="your-openai-api-key"
